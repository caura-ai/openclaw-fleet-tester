# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Required — OpenAI API key used to authenticate OpenClaw agents on each VM
OPENAI_API_KEY=sk-proj-...

# Required — MemClaw tenant-scoped API key
# Get this from https://memclaw.net → Manage → API Keys
MEMCLAW_API_KEY=mc_...

# Optional — MemClaw admin key
# Needed for NEXUS trust-level promotion and privileged verify.py checks
# If omitted, verify.py falls back to MEMCLAW_API_KEY
MEMCLAW_ADMIN_KEY=mc_admin_...

# GCP configuration
GCP_PROJECT=alpine-theory-469016-c8
GCP_ZONE=us-central1-a

# Number of VMs to provision (1–10). Fleet definitions in config.py cover up to 3.
VM_COUNT=3

# User prefix — REQUIRED when multiple team members run the tester simultaneously.
# Scopes VM names and fleet IDs so runs don't collide.
# Example: TESTER_PREFIX=alice → VMs: alice-openclaw-vm-01 … fleets: alice-fleet-01 …
# Leave blank for no prefix (solo use only).
TESTER_PREFIX=yourname
